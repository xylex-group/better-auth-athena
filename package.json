{
  "name": "@xylex-group/better-auth-athena",
  "version": "1.0.0",
  "description": "A better-Auth database adapter for @xylex-group/athena",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CONTRIBUTORS.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run typecheck && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xylex-group/better-auth-athena.git"
  },
  "keywords": [
    "better-auth",
    "athena",
    "database",
    "adapter"
  ],
  "author": "XYLEX GROUP",
  "contributors": [
    "floris-xlx"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "bugs": {
    "url": "https://github.com/xylex-group/better-auth-athena/issues"
  },
  "homepage": "https://github.com/xylex-group/better-auth-athena#readme",
  "peerDependencies": {
    "@xylex-group/athena": "^1.1.1",
    "better-auth": "^1.5.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@xylex-group/athena": "^1.1.1",
    "better-auth": "^1.5.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
